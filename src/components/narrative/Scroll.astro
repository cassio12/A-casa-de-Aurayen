---
interface Props {
  class?: string;
}

const { class: className = '' } = Astro.props;
---

<div
  class:list={[
    'relative rounded-sm border border-parchment-300 bg-parchment-50 px-8 py-10 md:px-12 md:py-14',
    'before:absolute before:inset-y-4 before:left-0 before:w-1 before:bg-sepia-light/40',
    className,
  ]}
>
  <slot />
</div>
