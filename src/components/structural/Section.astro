---
interface Props {
  title?: string;
  subtitle?: string;
  class?: string;
  id?: string;
}

const { title, subtitle, class: className = '', id } = Astro.props;
---

<section id={id} class:list={['py-16 md:py-22', className]}>
  {
    (title || subtitle) && (
      <header class="mb-12 text-center">
        {title && <h2 class="mb-4">{title}</h2>}
        {subtitle && (
          <p class="mx-auto max-w-prose text-lg text-ink-faint">{subtitle}</p>
        )}
      </header>
    )
  }
  <slot />
</section>
